# Backend
# Set this for local server or in your deployment environment.

OPENAI_API_KEY=

# Optional: comma-separated OpenAI model IDs to show/use for debate fan-out.
# If unset, the backend defaults to a small set (see backend/providers/openai_multi_provider.py).
# OPENAI_DEBATE_MODELS=gpt-4o-mini,gpt-4o,o3-mini

# Cost & caching controls
# Default maximum output tokens per model call (reduce to save credits)
# DEFAULT_MAX_TOKENS=256

# Hard cap on how many models can run per message (even if the UI selects more)
# MAX_MODELS_PER_ROUND=3

# Cache TTL (seconds) for identical requests to avoid re-calling OpenAI
# DEFAULT_CACHE_TTL_SEC=300

# Cache TTL (seconds) for /models listing
# OPENAI_MODEL_CACHE_TTL_SEC=300

# Frontend (optional; for custom API URL)
# VITE_API_URL=http://localhost:8080
