# Backend (non-secret config)
# Put secrets (like OPENAI_API_KEY) in `a.env`, not in `.env`.

# Optional: comma-separated OpenAI model IDs to show/use for debate fan-out.
# If unset, the backend defaults to a small set (see backend/providers/openai_multi_provider.py).
# OPENAI_DEBATE_MODELS=gpt-4o-mini,gpt-4o,o3-mini

# Cost & caching controls
# Default maximum output tokens per model call (reduce to save credits)
# DEFAULT_MAX_TOKENS=256

# Hard cap on how many models can run per message (even if the UI selects more)
# MAX_MODELS_PER_ROUND=3

# Cache TTL (seconds) for identical requests to avoid re-calling OpenAI
# DEFAULT_CACHE_TTL_SEC=300

# Cache TTL (seconds) for /models listing
# OPENAI_MODEL_CACHE_TTL_SEC=300

# Structured debate pipeline cost controls
# DEBATE_HISTORY_TURNS=2
# DEBATE_HISTORY_USER_MAX_CHARS=2000
# DEBATE_HISTORY_ASSISTANT_MAX_CHARS=800
# DEBATE_MODE=full  # or: short

# Frontend (optional; for custom API URL)
# VITE_API_URL=http://localhost:8080

# Instagram (optional)
# IG_GRAPH_BASE=https://graph.instagram.com
# IG_API_VERSION=v21.0
# IG_MODEL_POOL=gpt-4o-mini,gpt-4o,o3-mini
# IG_THREAD_MAX_MESSAGES=60
# IG_MESSAGE_MAX_CHARS=900
# IG_SEND_DELAY_MS=250

# Telegram (optional; supports group chats)
# TG_TRIGGER=command_or_mention
# TG_DEFAULT_PIPELINE=debate
# TG_ALLOWED_CHAT_IDS=
# TG_MODEL_POOL=gpt-4o-mini,gpt-4o,o3-mini
# TG_THREAD_MAX_MESSAGES=80
# TG_PANEL_COMBINE=1
# TG_SEND_DELAY_MS=250
# TG_PERSONA_DELAY_MS=250
# TG_COOLDOWN_SEC=0
# TG_WEBHOOK_SECRET_TOKEN=
# TG_POLLING=0
# TG_POLL_TIMEOUT_SEC=30
