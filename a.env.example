# Secrets for local dev (DO NOT COMMIT `a.env`)
#
# Copy to `a.env` and fill in values:
#   cp a.env.example a.env
#

# OpenAI
OPENAI_API_KEY=

# Instagram Messaging API (optional; requires an Instagram professional account + Meta app)
IG_ACCESS_TOKEN=
IG_USER_ID=
IG_VERIFY_TOKEN=
IG_APP_SECRET=

# Telegram Bot API (optional; supports group chats)
TG_BOT_TOKEN=
TG_BOT_USERNAME=
TG_WEBHOOK_SECRET_TOKEN=
